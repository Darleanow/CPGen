PROJECT_NAME           = "CPGen"
PROJECT_BRIEF          = "C++ project generator"
OUTPUT_DIRECTORY       = ./docs

INPUT                  = ./src ./include
RECURSIVE              = YES
FILE_PATTERNS          = *.c *.h *.cpp *.hpp *.asm

GENERATE_HTML          = YES
